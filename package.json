{
  "name": "figma",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source tools for moving designs between the browser and Figma.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "test": "pnpm -r run test",
    "check-types": "pnpm -r run check-types",
    "lint": "biome check",
    "format": "biome check --write",
    "changeset": "changeset",
    "release": "pnpm build && pnpm changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.27.13",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "lefthook": "^2.1.6",
    "pkg-pr-new": "^0.0.70",
    "ultracite": "7.6.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  }
}
