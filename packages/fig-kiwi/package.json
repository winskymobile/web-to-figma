{
  "name": "@figit/fig-kiwi",
  "version": "0.1.0",
  "description": "Encode Figma's Kiwi binary format and HTML clipboard envelope.",
  "license": "MIT",
  "author": "Figit <https://figit.design>",
  "homepage": "https://github.com/figitdesign/web-to-figma#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/figitdesign/web-to-figma.git",
    "directory": "packages/fig-kiwi"
  },
  "bugs": {
    "url": "https://github.com/figitdesign/web-to-figma/issues"
  },
  "keywords": [
    "figma",
    "fig",
    "kiwi",
    "kiwi-schema",
    "fig-kiwi",
    "design-tools",
    "clipboard",
    "encoder"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "lint": "biome check",
    "extract-schema": "tsx ./scripts/extract-schema.ts",
    "oracle:capture": "tsx ./scripts/oracle-capture.ts",
    "oracle:diff": "tsx ./scripts/oracle-diff.ts",
    "oracle:distill": "tsx ./scripts/oracle-distill.ts"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "fzstd": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "kiwi-schema": "^0.5.0",
    "tsdown": "^0.21.0",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  }
}
