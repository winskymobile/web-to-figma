{
  "name": "@sleekdesign/dom-to-figma",
  "version": "0.0.1",
  "description": "Convert any DOM tree to a Figma clipboard payload, in the browser.",
  "license": "MIT",
  "author": "Sleek Design <https://sleek.design>",
  "homepage": "https://github.com/sleekdotdesign/figma#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sleekdotdesign/figma.git",
    "directory": "packages/dom-to-figma"
  },
  "bugs": {
    "url": "https://github.com/sleekdotdesign/figma/issues"
  },
  "keywords": [
    "figma",
    "dom",
    "html-to-figma",
    "dom-to-figma",
    "design-tools",
    "clipboard",
    "converter",
    "browser"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/figma.d.mts",
      "import": "./dist/figma.mjs"
    }
  },
  "main": "./dist/figma.mjs",
  "types": "./dist/figma.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "lint": "biome check"
  },
  "dependencies": {
    "colorjs.io": "^0.6.1",
    "opentype.js": "^1.3.4",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/opentype.js": "^1.3.9",
    "@types/pako": "^2.0.4",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "happy-dom": "^20.9.0",
    "playwright": "^1.50.0",
    "tsdown": "^0.21.0",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  }
}
